rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /fixed_categories/{docId} {
      allow read: if request.auth != null;
    }

    match /fixed_pools/{categoryId}/{document=**} {
      allow read: if request.auth != null;
    }

    match /usernames/{usernameLower} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.usernameLower == usernameLower;

      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.usernameLower == usernameLower;

      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // PvP-related economy fields (coins/xp/rating/streaks/season tracking)
    // are now computed and written server-side by Cloud Functions
    // (finalizePvpMatch, finalizeAsyncPvpMatch, claimPvpSeasonRewards) —
    // the client may no longer write them directly. Everything else on
    // this doc (profile fields, cosmetics, etc.) stays client-writable.
    // More fields move into this list as later phases land.
    function pvpProtectedFields() {
      return [
        'coins', 'xp',
        'pvpRating', 'pvpRatingDelta', 'pvpLeagueId', 'pvpLeagueName',
        'bestLeagueId', 'bestLeagueName', 'bestLeagueEmoji',
        'bestLeagueColorValue',
        'currentPvpSeasonId', 'pvpSeasonBestRating',
        'pvpSeasonBestLeagueId', 'pvpSeasonBestLeagueName',
        'pvpSeasonFinalRating', 'pvpSeasonFinalLeagueId',
        'pvpSeasonFinalLeagueName',
        'pvpAbandonCount', 'pvpCooldownUntil', 'lastPvpPenaltyReason',
        'wins1v1', 'losses1v1', 'draws1v1', 'matches1v1',
        'currentWinStreak1v1', 'bestWinStreak1v1',
        'lastRankedXpEarned', 'lastRankedCoinsEarned',
        'lastClaimedPvpSeasonId', 'lastPvpSeasonRewardCoins',
        'lastPvpSeasonRewardCount', 'lastPvpSeasonRewardClaimedAt'
      ];
    }

    match /users/{userId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.coins == 0
        && request.resource.data.xp == 0;

      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(pvpProtectedFields());

      match /ai_topics/{topicId} {
        allow read, create, update, delete: if request.auth != null
          && request.auth.uid == userId;

        match /{document=**} {
          allow read, create, update, delete: if request.auth != null
            && request.auth.uid == userId;
        }
      }

      match /progress_fixed/{docId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /sessions_fixed/{docId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /progress_ai/{topicId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /sessions_ai/{sessionId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /daily_challenges/{dateId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /weekly_participation/{weekId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /season_history/{seasonId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /pvp_season_history/{seasonId} {
        allow read: if request.auth != null
          && request.auth.uid == userId;
        allow write: if false;
      }

      match /pvp_season_stats/{seasonId} {
        allow read: if request.auth != null
          && request.auth.uid == userId;
        allow write: if false;
      }

      match /match_history/{historyId} {
        allow read: if request.auth != null
          && request.auth.uid == userId;
        allow write: if false;
      }

      match /achievements/{achievementId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      match /friends/{friendId} {
        allow read, write: if request.auth != null
          && (
            request.auth.uid == userId ||
            request.auth.uid == friendId
          );
      }

      match /friend_requests/{requesterId} {
        allow read: if request.auth != null
          && (
            request.auth.uid == userId ||
            request.auth.uid == requesterId
          );

        allow create, update, delete: if request.auth != null
          && (
            request.auth.uid == userId ||
            request.auth.uid == requesterId
          );
      }

      match /sent_friend_requests/{targetId} {
        allow read: if request.auth != null
          && request.auth.uid == userId;

        allow create, update, delete: if request.auth != null
          && (
            request.auth.uid == userId ||
            request.auth.uid == targetId
          );
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null
          && request.auth.uid == userId;

        allow create: if request.auth != null;

        allow update: if request.auth != null
          && request.resource.data.type == resource.data.type
          && request.resource.data.read == false;
      }
    }

    match /daily_leaderboards/{dateId}/players/{playerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == playerId;
    }

    match /weekly_leagues/{weekId}/{leagueId}/{playerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == playerId;
    }

    // Matches are 1v1 — only the two players in a match may read or write
    // it. `create` covers both a fresh match (creator lists themself as
    // hostUid) and a rematch doc (creator may be listed as guestUid,
    // since either player can trigger rematch creation). `update` also
    // allows a brand-new joiner to claim an empty guestUid slot
    // (MatchService.joinMatch), since at that moment they aren't yet
    // host or guest on the existing doc.
    match /matches/{matchId} {
      allow read: if request.auth != null
        && (
          request.auth.uid == resource.data.hostUid ||
          request.auth.uid == resource.data.guestUid
        );

      allow create: if request.auth != null
        && (
          request.auth.uid == request.resource.data.hostUid ||
          request.auth.uid == request.resource.data.guestUid
        );

      allow update: if request.auth != null
        && (
          request.auth.uid == resource.data.hostUid ||
          request.auth.uid == resource.data.guestUid ||
          (
            resource.data.guestUid == null &&
            request.resource.data.guestUid == request.auth.uid
          )
        );
    }

    match /weekly_topics/{topicId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Same reasoning as /matches — only the challenger and the challenged
    // player may read or write an async match. Both UIDs are always set
    // at creation (no open "guest slot" here), so create/update only need
    // the participant check, no empty-slot claim clause.
    match /async_matches/{matchId} {
      allow read: if request.auth != null
        && (
          request.auth.uid == resource.data.challengerUid ||
          request.auth.uid == resource.data.challengedUid
        );

      allow create: if request.auth != null
        && (
          request.auth.uid == request.resource.data.challengerUid ||
          request.auth.uid == request.resource.data.challengedUid
        );

      allow update: if request.auth != null
        && (
          request.auth.uid == resource.data.challengerUid ||
          request.auth.uid == resource.data.challengedUid
        );
    }

    match /realtime_invites/{inviteId} {
      allow read: if request.auth != null
        && (
          request.auth.uid == resource.data.fromUid ||
          request.auth.uid == resource.data.toUid
        );

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid;

      allow update: if request.auth != null
        && (
          request.auth.uid == resource.data.fromUid ||
          request.auth.uid == resource.data.toUid
        );

      allow delete: if false;
    }

    match /live_search/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
